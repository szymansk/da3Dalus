# Example environment configuration for cad-modelling-service.
# Copy this file to `.env` and fill in the values you need.
# `.env` is gitignored — NEVER commit real secrets.

# --- Database ---------------------------------------------------------------
# SQLAlchemy connection URL. Defaults to a local SQLite file if unset
# (see app/db/session.py). Override in production.
# Examples:
#   sqlite:///./db/test.db
#   postgresql+psycopg2://user:pass@localhost:5432/da3dalus
SQLALCHEMY_DATABASE_URL=sqlite:///./db/test.db

# --- Logging ----------------------------------------------------------------
# Python logging level. One of: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# Read by app/logging_config.py.
LOG_LEVEL=INFO

# --- Headless rendering (visualisation / 3-view / streamline plots) ---------
# Path to a Chromium-compatible browser used by headless rendering flows.
# On the provided Docker image this is /usr/bin/chromium.
BROWSER_PATH=/usr/bin/chromium

# Qt platform for headless rendering. Keep as "offscreen" on servers.
QT_QPA_PLATFORM=offscreen

# --- CadQuery live viewer (optional, local development only) ---------------
# Host and port of a running ocp-vscode viewer. Used by
# cad_designer/cq_plugins/display/display.py to preview CAD during dev.
# Leave at defaults if you don't run the viewer.
OCP_VSCODE_HOST=127.0.0.1
OCP_VSCODE_PORT=3939

# --- Uvicorn ----------------------------------------------------------------
# Host address for the uvicorn dev server (run_app). Defaults to 127.0.0.1.
# Set to 0.0.0.0 in Docker/production to accept external connections.
UVICORN_HOST=127.0.0.1

# --- Debug flags ------------------------------------------------------------
# When set to 1/ON/TRUE/ENABLED, decorated debug functions emit intermediate
# CAD steps during construction (see cad_designer/decorators/general_decorators.py
# and the conditional_execute decorator). Leave unset in production.
# DISPLAY_CONSTRUCTION_STEP=

  # --- SonarQube / SonarCloud -------------------------------------------------                                                                                                                                                                                         
  # Authentication token for the SonarCloud API. Used by supercycle skills
  # to fetch quality-gate results. Generate at https://sonarcloud.io/account/security                                                                                                                                                                                    
  # SONAR_TOKEN=
                      