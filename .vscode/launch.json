{
    // Verwendet IntelliSense zum Ermitteln möglicher Attribute.
    // Zeigen Sie auf vorhandene Attribute, um die zugehörigen Beschreibungen anzuzeigen.
    // Weitere Informationen finden Sie unter https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FastAPI: app.main",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--host",
                "127.0.0.1",
                "--port",
                "8001",
                "--reload"
            ],
            "jinja": true,
            "justMyCode": true,
            "console": "integratedTerminal"
        },
        {
            "name": "MCP: app.mcp_server",
            "type": "python",
            "request": "launch",
            "module": "app.mcp_server",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONUNBUFFERED": "1"
            }
        },
        {
            "name": "Python: Aktuelle Datei",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "type": "dockerfile",
            "request": "launch",
            "name": "Docker: Build",
            "dockerfile": "Dockerfile",
            "contextPath": "${workspaceFolder}"
        },
        {
            "name": "eHawk Wing (run)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/test/Construction_eHawk_wing.py",
            "cwd": "${workspaceFolder}/test",
            "console": "integratedTerminal",
            "env": {
                "DISPLAY_CONSTRUCTION_STEP": "FALSE",
                "PYTHONUNBUFFERED": "1",
                "PYTHONFAULTHANDLER": "1",
                "QT_QPA_PLATFORM": "offscreen",
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        },
        {
            "name": "eHawk Wing (with ocp-vscode viewer)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/test/Construction_eHawk_wing.py",
            "cwd": "${workspaceFolder}/test",
            "console": "integratedTerminal",
            "env": {
                "PYTHONUNBUFFERED": "1",
                "DISPLAY_CONSTRUCTION_STEP": "TRUE",
                "OCP_VSCODE_HOST": "127.0.0.1",
                "OCP_VSCODE_PORT": "3939",
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false,
            "preLaunchTask": ""
        }
    ]
}